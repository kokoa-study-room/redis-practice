{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "datasource",
          "uid": "grafana"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Redis 학습용 미니 대시보드. redis_exporter v1.82.0 메트릭 기준. ID 763 (Redis - Prometheus Redis Exporter 1.x) 의 핵심 패널을 단순화하여 추출. 출처: https://grafana.com/grafana/dashboards/763",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "uid": "redis-learning-mini",
  "title": "Redis Learning — Mini Dashboard",
  "tags": ["redis", "learning"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(redis_up, instance)",
        "name": "instance",
        "query": "label_values(redis_up, instance)",
        "refresh": 2,
        "type": "query",
        "current": {
          "selected": false,
          "text": "redis-mon",
          "value": "redis-mon"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Redis Up",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "redis_up{instance=\"$instance\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Connected Clients",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "redis_connected_clients{instance=\"$instance\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Used Memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        }
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{instance=\"$instance\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Keys (db0)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(redis_db_keys{instance=\"$instance\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Hit Ratio (last 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{instance=\"$instance\"}[5m]) / clamp_min(rate(redis_keyspace_hits_total{instance=\"$instance\"}[5m]) + rate(redis_keyspace_misses_total{instance=\"$instance\"}[5m]), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Uptime",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "redis_uptime_in_seconds{instance=\"$instance\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Commands per second (rate 1m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{instance=\"$instance\"}[1m])",
          "legendFormat": "{{instance}} cmds/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory used vs maxmemory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "decbytes" }
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{instance=\"$instance\"}",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes{instance=\"$instance\"}",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Hits / Misses per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{instance=\"$instance\"}[1m])",
          "legendFormat": "hits",
          "refId": "A"
        },
        {
          "expr": "rate(redis_keyspace_misses_total{instance=\"$instance\"}[1m])",
          "legendFormat": "misses",
          "refId": "B"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Connected clients / blocked clients",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "redis_connected_clients{instance=\"$instance\"}",
          "legendFormat": "connected",
          "refId": "A"
        },
        {
          "expr": "redis_blocked_clients{instance=\"$instance\"}",
          "legendFormat": "blocked",
          "refId": "B"
        }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Net I/O (bytes/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      },
      "targets": [
        {
          "expr": "rate(redis_net_input_bytes_total{instance=\"$instance\"}[1m])",
          "legendFormat": "in",
          "refId": "A"
        },
        {
          "expr": "rate(redis_net_output_bytes_total{instance=\"$instance\"}[1m])",
          "legendFormat": "out",
          "refId": "B"
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Expired / Evicted keys per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "expr": "rate(redis_expired_keys_total{instance=\"$instance\"}[1m])",
          "legendFormat": "expired",
          "refId": "A"
        },
        {
          "expr": "rate(redis_evicted_keys_total{instance=\"$instance\"}[1m])",
          "legendFormat": "evicted",
          "refId": "B"
        }
      ]
    }
  ]
}
