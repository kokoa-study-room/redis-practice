# ==============================================================================
# Python 예제용 환경변수 템플릿
# 사용법: cp .env.example .env  →  값 수정
# python-dotenv 가 있으면 예제 코드에서 자동 로딩.
# ==============================================================================

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=           # 학습 환경에서는 비어둠
# REDIS_USERNAME=default    # ACL 챕터에서 사용
